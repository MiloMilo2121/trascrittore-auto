# Required API keys
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Local folders. Relative paths are resolved from this project folder.
WATCH_DIR=./RECS
TRANSCRIPTS_DIR=./Trascrizioni
ARCHIVE_DIR=./Archivio

# OpenAI file-name extraction
OPENAI_MODEL=gpt-4o-mini

# Post-call email drafts
EMAIL_DRAFTS_ENABLED=true
EMAIL_DRAFTS_DIR=./BozzeEmail
EMAIL_EXAMPLES_DIR=./EsempiEmail
CALENDAR_CONTEXT_DIR=./EventiCalendar
KNOWN_DATA_DIR=./DatiLead
EMAIL_MODEL=
DEFAULT_SELLER_NAME=Marco
SENDER_NAME=Francesca
SENDER_PHONE=3500938174
VAT_RESEARCH_ENABLED=true
# Search-engine fallback is intentionally off by default because P.IVA must be verified.
VAT_SEARCH_FALLBACK_ENABLED=false
VAT_RESEARCH_TIMEOUT_SECONDS=8
EMAIL_MAX_EXAMPLES=8
EMAIL_MAX_EXAMPLE_CHARS=8000
EMAIL_MAX_TRANSCRIPT_CHARS=120000
EMAIL_MAX_CALENDAR_CHARS=20000
EMAIL_MAX_OUTPUT_TOKENS=6000

# Optional Google OAuth integrations. Leave disabled until OAuth files are available.
GOOGLE_OAUTH_CLIENT_SECRETS=./google_oauth_client_secret.json
GOOGLE_OAUTH_TOKEN=./google_oauth_token.json
GOOGLE_OAUTH_LOCAL_PORT=8080
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_LOOKUP_BEFORE_MINUTES=120
GOOGLE_CALENDAR_LOOKUP_AFTER_MINUTES=30
GOOGLE_CALENDAR_NEXT_MEETING_DAYS=45
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEET_ID=
GOOGLE_SHEET_RANGE=FollowUp!A:Z

# AssemblyAI transcription
ASSEMBLYAI_LANGUAGE_DETECTION=true
ASSEMBLYAI_SPEECH_MODELS=universal-3-pro,universal-2
# Set this only if you are certain, for example: 2
ASSEMBLYAI_SPEAKERS_EXPECTED=

# File handling
DELETE_AUDIO_AFTER_PROCESSING=false
FILE_STABILITY_INTERVAL_SECONDS=2
FILE_STABILITY_REQUIRED_CHECKS=3
FILE_QUIET_SECONDS=120
POLL_INTERVAL_SECONDS=5
PROCESSING_TIMEOUT_SECONDS=10800
