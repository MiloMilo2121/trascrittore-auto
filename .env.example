# Required API keys
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Local folders. Relative paths are resolved from this project folder.
WATCH_DIR=./RECS
TRANSCRIPTS_DIR=./Trascrizioni
ARCHIVE_DIR=./Archivio

# OpenAI file-name extraction
OPENAI_MODEL=gpt-4o-mini

# Post-call email drafts
EMAIL_DRAFTS_ENABLED=true
EMAIL_DRAFTS_DIR=./BozzeEmail
EMAIL_EXAMPLES_DIR=./EsempiEmail
CALENDAR_CONTEXT_DIR=./EventiCalendar
EMAIL_MODEL=
EMAIL_MAX_EXAMPLES=8
EMAIL_MAX_EXAMPLE_CHARS=8000
EMAIL_MAX_TRANSCRIPT_CHARS=120000
EMAIL_MAX_CALENDAR_CHARS=20000
EMAIL_MAX_OUTPUT_TOKENS=6000

# AssemblyAI transcription
ASSEMBLYAI_LANGUAGE_DETECTION=true
ASSEMBLYAI_SPEECH_MODELS=universal-3-pro,universal-2
# Set this only if you are certain, for example: 2
ASSEMBLYAI_SPEAKERS_EXPECTED=

# File handling
DELETE_AUDIO_AFTER_PROCESSING=false
FILE_STABILITY_INTERVAL_SECONDS=2
FILE_STABILITY_REQUIRED_CHECKS=3
FILE_QUIET_SECONDS=120
POLL_INTERVAL_SECONDS=5
PROCESSING_TIMEOUT_SECONDS=10800
